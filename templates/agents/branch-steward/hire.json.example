{
  "name": "Branch Steward",
  "role": "devops",
  "title": "Repository Branch Custodian",
  "icon": "git-branch",
  "reportsTo": "<your-cto-or-engineering-manager-agent-id>",
  "capabilities": "Reaps ghost branches across the configured repos by cross-referencing each branch with its linked Bedlam issue. Deletes merged-into-main branches, archives premature branches, comments on stale in-progress branches. The only agent allowed to delete branches. Does not write code, does not approve, does not merge.",
  "adapterType": "codex_local",
  "adapterConfig": {
    "cwd": "<absolute-path-to-a-repo-clone-with-gh-auth>",
    "env": {
      "GIT_AUTHOR_NAME": {"type": "plain", "value": "branch-steward"},
      "GIT_AUTHOR_EMAIL": {"type": "plain", "value": "agents@example.com"},
      "GIT_COMMITTER_NAME": {"type": "plain", "value": "branch-steward"},
      "GIT_COMMITTER_EMAIL": {"type": "plain", "value": "agents@example.com"}
    },
    "model": "<your-model-id>",
    "graceSec": 15,
    "timeoutSec": 3600,
    "maxTurnsPerRun": 40,
    "model_reasoning_effort": "high",
    "dangerouslyBypassApprovalsAndSandbox": true
  },
  "runtimeConfig": {
    "heartbeat": {
      "enabled": true,
      "cooldownSec": 30,
      "intervalSec": 86400,
      "wakeOnDemand": true,
      "maxConcurrentRuns": 1
    }
  }
}
