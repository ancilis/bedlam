{
  "name": "Merger",
  "role": "devops",
  "title": "Release Merge Operator",
  "icon": "package",
  "reportsTo": "<your-cto-or-engineering-manager-agent-id>",
  "capabilities": "Lands approved PRs to main: squash-merge, branch delete, Bedlam issue close, dependent-issue unblock. Watches the configured repos for PRs in mergeable+approved state. Reverts the merge if main CI goes red within 10 minutes. Does not write code, does not approve, does not push commits.",
  "adapterType": "codex_local",
  "adapterConfig": {
    "cwd": "<absolute-path-to-a-repo-clone-with-gh-auth>",
    "env": {
      "GIT_AUTHOR_NAME": {"type": "plain", "value": "merger"},
      "GIT_AUTHOR_EMAIL": {"type": "plain", "value": "agents@example.com"},
      "GIT_COMMITTER_NAME": {"type": "plain", "value": "merger"},
      "GIT_COMMITTER_EMAIL": {"type": "plain", "value": "agents@example.com"}
    },
    "model": "<your-model-id>",
    "graceSec": 15,
    "timeoutSec": 3600,
    "maxTurnsPerRun": 40,
    "model_reasoning_effort": "high",
    "dangerouslyBypassApprovalsAndSandbox": true
  },
  "runtimeConfig": {
    "heartbeat": {
      "enabled": true,
      "cooldownSec": 10,
      "intervalSec": 1800,
      "wakeOnDemand": true,
      "maxConcurrentRuns": 1
    }
  }
}
